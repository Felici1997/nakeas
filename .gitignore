# Créer un fichier .gitignore complet pour Laravel
@"
/node_modules
/public/hot
/public/storage
/storage/*.key
/vendor
core/.env
.env
.env.backup
.phpunit.result.cache
docker-compose.override.yml
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
/.idea
/.vscode
"@ | Out-File -FilePath .gitignore -Encoding utf8